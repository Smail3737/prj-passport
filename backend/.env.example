# PostgreSQL connection string for Prisma
# Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/project_passport?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/project_passport?schema=public"

# Remote AI URL
REMOTE_AI_BASE_URL="https://text.pollinations.ai"

# Optional AI request timeout in milliseconds
AI_REQUEST_TIMEOUT_MS="60000"
