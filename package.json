{
  "name": "project-passport",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "sh -c 'npm run backend:dev & BACK_PID=$!; trap \"kill $BACK_PID\" EXIT; npm run frontend:dev'",
    "dev": "npm run start",
    "frontend:dev": "npm run dev --workspace frontend",
    "backend:dev": "npm run dev --workspace backend",
    "frontend:build": "npm run build --workspace frontend",
    "frontend:preview": "npm run preview --workspace frontend",
    "backend:test": "npm run test --workspace backend",
    "build": "npm run frontend:build",
    "lint": "npm run lint --workspace frontend",
    "test:api": "npm run backend:test",
    "web:serve": "npm run serve:web --workspace backend",
    "demo:link": "node scripts/public-link.mjs"
  },
  "devDependencies": {
    "localtunnel": "^2.0.2"
  }
}
